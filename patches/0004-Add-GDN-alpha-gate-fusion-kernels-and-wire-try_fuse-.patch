+/* fused add + softplus (+ optional channel-wise mul gate) */
+
+template <typename T>
+static __global__ void add_softplus_kernel(const T * x, const T * bias, T * dst, const int64_t k, const int64_t nc) {
+    ggml_cuda_pdl_lc();
+    const int64_t i = int64_t(blockDim.x)*blockIdx.x + threadIdx.x;
+
+    if (i >= k) {
+        return;
+    }
+
+    const int64_t c  = i % nc;
+    const float sp = op_softplus((float) x[i] + (float) bias[c]);
+
+    ggml_cuda_pdl_sync();
+    dst[i] = (T) sp;
+}
+
+template <typename T>
+static __global__ void add_softplus_mul_kernel(const T * x, const T * bias, const T * gate, T * dst,
+        const int64_t k, const int64_t nc) {
+    ggml_cuda_pdl_lc();
+    const int64_t i = int64_t(blockDim.x)*blockIdx.x + threadIdx.x;
+
+    if (i >= k) {
+        return;
+    }
+
+    const int64_t c  = i % nc;
+    const float sp = op_softplus((float) x[i] + (float) bias[c]);
+
+    ggml_cuda_pdl_sync();
+    dst[i] = (T) (sp * (float) gate[c]);
+}
+
+template <typename T>
+static void add_softplus_cuda(const T * x, const T * bias, T * dst, const int64_t k, const int64_t nc, cudaStream_t stream) {
+    const int64_t num_blocks = (k + CUDA_GLU_BLOCK_SIZE - 1) / CUDA_GLU_BLOCK_SIZE;
+    const ggml_cuda_kernel_launch_params launch_params = ggml_cuda_kernel_launch_params((dim3) num_blocks, CUDA_GLU_BLOCK_SIZE, 0, stream);
+    ggml_cuda_kernel_launch(add_softplus_kernel<T>, launch_params, x, bias, dst, k, nc);
+}
+
+template <typename T>
+static void add_softplus_mul_cuda(const T * x, const T * bias, const T * gate, T * dst,
+        const int64_t k, const int64_t nc, cudaStream_t stream) {
+    const int64_t num_blocks = (k + CUDA_GLU_BLOCK_SIZE - 1) / CUDA_GLU_BLOCK_SIZE;
+    const ggml_cuda_kernel_launch_params launch_params = ggml_cuda_kernel_launch_params((dim3) num_blocks, CUDA_GLU_BLOCK_SIZE, 0, stream);
+    ggml_cuda_kernel_launch(add_softplus_mul_kernel<T>, launch_params, x, bias, gate, dst, k, nc);
+}
+
+static void ggml_cuda_op_add_softplus_impl(ggml_backend_cuda_context & ctx, ggml_tensor * add_node, ggml_tensor * softplus_node, ggml_tensor * mul_node) {
+    const ggml_tensor * bias = (ggml_nelements(add_node->src[0]) < ggml_nelements(add_node->src[1])) ? add_node->src[0] : add_node->src[1];
+    const ggml_tensor * x    = (bias == add_node->src[0]) ? add_node->src[1] : add_node->src[0];
+
+    const ggml_tensor * gate = mul_node ? ((mul_node->src[0] == softplus_node) ? mul_node->src[1] : mul_node->src[0]) : nullptr;
+    const ggml_tensor * out = mul_node ? mul_node : softplus_node;
+
+    GGML_ASSERT(x->type == GGML_TYPE_F32);
+    GGML_ASSERT(bias->type == GGML_TYPE_F32);
+    GGML_ASSERT(out->type == GGML_TYPE_F32);
+    GGML_ASSERT(ggml_is_contiguous(x));
+    GGML_ASSERT(ggml_is_contiguous(bias));
+    GGML_ASSERT(ggml_is_contiguous(out));
+    GGML_ASSERT(ggml_nelements(bias) == out->ne[0]);
+    GGML_ASSERT(bias->ne[0] == out->ne[0]);
+    GGML_ASSERT(ggml_are_same_shape(x, out));
+
+    if (mul_node) {
+        GGML_ASSERT(gate->type == GGML_TYPE_F32);
+        GGML_ASSERT(ggml_is_contiguous(gate));
+        GGML_ASSERT(ggml_nelements(gate) == out->ne[0]);
+        GGML_ASSERT(gate->ne[0] == out->ne[0]);
+    }
+
+    const int64_t k  = ggml_nelements(out);
+    const int64_t nc = out->ne[0];
+
+    cudaStream_t stream = ctx.stream();
+
+    if (mul_node) {
+        add_softplus_mul_cuda((const float *) x->data, (const float *) bias->data, (const float *) gate->data,
+                (float *) out->data, k, nc, stream);
+    } else {
+        add_softplus_cuda((const float *) x->data, (const float *) bias->data,
+                (float *) out->data, k, nc, stream);
+    }
+}
+
+void ggml_cuda_op_add_softplus(ggml_backend_cuda_context & ctx, ggml_tensor * add_node, ggml_tensor * softplus_node) {
+    ggml_cuda_op_add_softplus_impl(ctx, add_node, softplus_node, nullptr);
+}
+
+void ggml_cuda_op_add_softplus_mul(ggml_backend_cuda_context & ctx, ggml_tensor * add_node, ggml_tensor * softplus_node, ggml_tensor * mul_node) {
+    ggml_cuda_op_add_softplus_impl(ctx, add_node, softplus_node, mul_node);
+}
