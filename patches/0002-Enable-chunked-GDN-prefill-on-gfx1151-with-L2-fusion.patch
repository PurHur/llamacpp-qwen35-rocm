diff --git a/ggml/src/ggml-cuda/gated_delta_net_chunked.cu b/ggml/src/ggml-cuda/gated_delta_net_chunked.cu
index 72f165ed..72963e49 100644
--- a/ggml/src/ggml-cuda/gated_delta_net_chunked.cu
+++ b/ggml/src/ggml-cuda/gated_delta_net_chunked.cu
@@ -6,23 +6,22 @@
 #include <climits>
 
 #ifndef GGML_CUDA_GDN_CHUNK_SIZE
-#    define GGML_CUDA_GDN_CHUNK_SIZE 64
+#    if defined(RDNA3_5)
+        // gfx1151: 64 KiB LDS; state scratch uses global memory, smaller CS keeps other kernels under LDS budget.
+#        define GGML_CUDA_GDN_CHUNK_SIZE 32
+#    else
+#        define GGML_CUDA_GDN_CHUNK_SIZE 64
+#    endif
 #endif
 
 #ifndef GGML_CUDA_GDN_CHUNK_THRESHOLD
-#    define GGML_CUDA_GDN_CHUNK_THRESHOLD 64
+#    define GGML_CUDA_GDN_CHUNK_THRESHOLD 16
 #endif
 
 #ifndef GGML_CUDA_GDN_CHUNKED
 #    define GGML_CUDA_GDN_CHUNKED 1
 #endif
 
-// RDNA3.5 (gfx1151): 64 KiB LDS; chunk output kernel with CS=64, S_v=128 exceeds the limit.
-#if defined(RDNA3_5)
-#    undef GGML_CUDA_GDN_CHUNKED
-#    define GGML_CUDA_GDN_CHUNKED 0
-#endif
-
 static int ggml_cuda_gdn_chunk_threshold_runtime() {
     static int thresh = -1;
     if (thresh < 0) {
@@ -76,6 +75,60 @@ bool ggml_cuda_gdn_use_chunked_prefill(int64_t n_tokens, int64_t S_v, bool kda,
 
 #if GGML_CUDA_GDN_CHUNKED
 
+template<int warp_size, int rows_per_lane>
+static __device__ __forceinline__ void gdn_l2_normalize_shard(float (& shard)[rows_per_lane], const float eps) {
+    float sum = 0.0f;
+#pragma unroll
+    for (int r = 0; r < rows_per_lane; r++) {
+        sum += shard[r] * shard[r];
+    }
+    const float scale = rsqrtf(fmaxf(warp_reduce_sum<warp_size>(sum), eps * eps));
+#pragma unroll
+    for (int r = 0; r < rows_per_lane; r++) {
+        shard[r] *= scale;
+    }
+}
+
+template <size_t S_v>
+static __global__ void gdn_l2_normalize_qk_kernel(float * q,
+                                                  float * k,
+                                                  int64_t s1,
+                                                  int64_t s2,
+                                                  int64_t s3,
+                                                  float   eps) {
+    const int h_idx = blockIdx.x;
+    const int t_idx = blockIdx.y;
+    const int s_idx = blockIdx.z;
+
+    float * q_row = q + (int64_t) h_idx * s1 + (int64_t) t_idx * s2 + (int64_t) s_idx * s3;
+    float * k_row = k + (int64_t) h_idx * s1 + (int64_t) t_idx * s2 + (int64_t) s_idx * s3;
+
+    constexpr int warp_size     = ggml_cuda_get_physical_warp_size() < (int) S_v ? ggml_cuda_get_physical_warp_size() : (int) S_v;
+    constexpr int rows_per_lane = ((int) S_v + warp_size - 1) / warp_size;
+    const int     lane          = threadIdx.x;
+
+    float q_reg[rows_per_lane];
+    float k_reg[rows_per_lane];
+#pragma unroll
+    for (int r = 0; r < rows_per_lane; r++) {
+        const int i = r * warp_size + lane;
+        q_reg[r]    = (i < (int) S_v) ? q_row[i] : 0.0f;
+        k_reg[r]    = (i < (int) S_v) ? k_row[i] : 0.0f;
+    }
+
+    gdn_l2_normalize_shard<warp_size, rows_per_lane>(q_reg, eps);
+    gdn_l2_normalize_shard<warp_size, rows_per_lane>(k_reg, eps);
+
+#pragma unroll
+    for (int r = 0; r < rows_per_lane; r++) {
+        const int i = r * warp_size + lane;
+        if (i < (int) S_v) {
+            q_row[i] = q_reg[r];
+            k_row[i] = k_reg[r];
+        }
+    }
+}
+
 template <size_t CS>
 static __global__ void gdn_chunk_cumsum_kernel(const float * g,
                                                float *       g_cs,
@@ -256,6 +309,7 @@ static __global__ void gdn_chunk_state_kernel(const float * k_raw,
                                               const float * state_in,
                                               float *       states_out,
                                               float *       state_final,
+                                              float *       work_state,
                                               int64_t       sk1,
                                               int64_t       sk2,
                                               int64_t       sk3,
@@ -270,7 +324,8 @@ static __global__ void gdn_chunk_state_kernel(const float * k_raw,
     const int seq_idx = blockIdx.y;
     const int64_t hs  = (int64_t) seq_idx * H + h_idx;
 
-    __shared__ float smem_state[S_v * S_v];
+    // Global scratch avoids 64 KiB __shared__ (gfx1151 LDS limit for S_v=128).
+    float * smem_state = work_state + hs * S_v * S_v;
 
     const float * s_in = state_in + hs * S_v * S_v;
     for (int idx = threadIdx.x; idx < (int) (S_v * S_v); idx += blockDim.x) {
@@ -416,6 +471,7 @@ void ggml_cuda_gdn_chunked_prefill(
         int64_t                     neqk1,
         int64_t                     rq3,
         float                       scale,
+        float                       fuse_l2_eps,
         cudaStream_t                stream) {
     static constexpr int CS = GGML_CUDA_GDN_CHUNK_SIZE;
 
@@ -427,10 +483,18 @@ void ggml_cuda_gdn_chunked_prefill(
         ggml_cuda_gdn_launch_ar(
             q_d, k_d, v_d, g_d, b_d, s_d, dst_d, state_d,
             S_v, H, n_tokens, n_seqs, sq1, sq2, sq3, sv1, sv2, sv3,
-            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, 0.0f, n_tokens, 0, stream);
+            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, fuse_l2_eps, n_tokens, 0, stream);
         return;
     }
 
+    if (fuse_l2_eps > 0.0f) {
+        float * q_mut = const_cast<float *>(q_d);
+        float * k_mut = const_cast<float *>(k_d);
+        dim3 grid((unsigned) H, (unsigned) n_full, (unsigned) n_seqs);
+        gdn_l2_normalize_qk_kernel<128><<<grid, 128, 0, stream>>>(q_mut, k_mut, sq1, sq2, sq3, fuse_l2_eps);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
     const int64_t ng1 = CS * n_chunks;
     const int64_t ng3 = CS * n_chunks * H;
 
@@ -492,12 +556,13 @@ void ggml_cuda_gdn_chunked_prefill(
 
     ggml_cuda_pool_alloc<float> states(ctx.pool(), S_v * S_v * n_chunks * H * n_seqs);
     ggml_cuda_pool_alloc<float> state_out(ctx.pool(), S_v * S_v * H * n_seqs);
+    ggml_cuda_pool_alloc<float> state_work(ctx.pool(), S_v * S_v * H * n_seqs);
 
     {
         dim3 grid(H, n_seqs);
         gdn_chunk_state_kernel<CS, 128><<<grid, 256, 0, stream>>>(
             k_d, v_new.get(), k_cd.get(), gate_csum.get(), s_d,
-            states.get(), state_out.get(),
+            states.get(), state_out.get(), state_work.get(),
             sq1, sq2, sq3, ng1, ng3, sd1, sd2, sd3, n_chunks, H);
         CUDA_CHECK(cudaGetLastError());
     }
@@ -523,7 +588,7 @@ void ggml_cuda_gdn_chunked_prefill(
         ggml_cuda_gdn_launch_ar(
             q_tail, k_tail, v_tail, g_tail, b_tail, state_out.get(), dst_d, state_d,
             S_v, H, n_tail, n_seqs, sq1, sq2, sq3, sv1, sv2, sv3,
-            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, 0.0f, n_tokens, n_full, stream);
+            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, fuse_l2_eps, n_tokens, n_full, stream);
     }
 }
 
@@ -558,8 +623,10 @@ void ggml_cuda_gdn_chunked_prefill(
         int64_t                     neqk1,
         int64_t                     rq3,
         float                       scale,
+        float                       fuse_l2_eps,
         cudaStream_t                stream) {
     GGML_UNUSED(ctx);
