-            sb1, sb2, sb3, sg1, sg2, sg3, neqk1, rq3, scale, stream);
+            sb1, sb2, sb3, sg1, sg2, sg3, neqk1, rq3, scale, fuse_l2, stream);
         return;
     }
 
