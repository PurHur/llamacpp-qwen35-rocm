         state_slot_stride = cache->slot_stride;
     }
 
-    if (!kda && !keep_rs && fuse_l2 == 0.0f && ggml_cuda_gdn_use_chunked_prefill(n_tokens, S_v, kda, K)) {
+    if (!kda && !keep_rs && ggml_cuda_gdn_use_chunked_prefill(n_tokens, S_v, kda, K)) {
         ggml_cuda_gdn_chunked_prefill(
             ctx, q_d, k_d, v_d, g_d, b_d, s_d, dst_d, state_d,
