+// SSM_CONV + SILU may be separated by view/noop nodes in Qwen35 GDN graphs.
+static int ggml_cuda_ssm_conv_silu_span(const ggml_cgraph * cgraph, int node_idx, ggml_tensor ** silu_out) {
+    const ggml_tensor * ssm_conv = cgraph->nodes[node_idx];
+    if (ssm_conv->op != GGML_OP_SSM_CONV) {
+        return 0;
+    }
+
+    int j = node_idx + 1;
+    while (j < cgraph->n_nodes && ggml_cuda_is_view_or_noop(cgraph->nodes[j])) {
+        j++;
+    }
+    if (j >= cgraph->n_nodes) {
+        return 0;
+    }
+
+    ggml_tensor * silu = cgraph->nodes[j];
+    if (silu->op != GGML_OP_UNARY || ggml_get_unary_op(silu) != GGML_UNARY_OP_SILU) {
+        return 0;
+    }
+
+    if (ggml_cuda_fuse_unary_src_root(silu->src[0]) != ssm_conv) {
+        return 0;
+    }
+
+    if (ssm_conv->type != GGML_TYPE_F32 || silu->type != GGML_TYPE_F32) {
+        return 0;
+    }
+
+    if (!ggml_node_has_n_uses(cgraph, node_idx, 1)) {
+        return 0;
+    }
+
+    *silu_out = silu;
+    return j - node_idx;
+}
