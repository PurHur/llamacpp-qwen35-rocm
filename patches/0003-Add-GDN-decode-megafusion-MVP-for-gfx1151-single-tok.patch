+static const ggml_tensor * ggml_cuda_fuse_unary_src_root(const ggml_tensor * t) {
+    while (t != nullptr && (t->op == GGML_OP_VIEW || t->op == GGML_OP_RESHAPE)) {
+        t = (t->op == GGML_OP_VIEW) ? t->view_src : t->src[0];
+    }
+    return t;
