diff --git a/ggml/src/ggml-cuda/gated_delta_net_chunked.cu b/ggml/src/ggml-cuda/gated_delta_net_chunked.cu
new file mode 100644
index 00000000..72f165ed
--- /dev/null
+++ b/ggml/src/ggml-cuda/gated_delta_net_chunked.cu
@@ -0,0 +1,594 @@
+#include "gated_delta_net.cuh"
+#include "solve_tri.cuh"
+#include "ggml-cuda/common.cuh"
+
+#include <cstdlib>
+#include <climits>
+
+#ifndef GGML_CUDA_GDN_CHUNK_SIZE
+#    define GGML_CUDA_GDN_CHUNK_SIZE 64
+#endif
+
+#ifndef GGML_CUDA_GDN_CHUNK_THRESHOLD
+#    define GGML_CUDA_GDN_CHUNK_THRESHOLD 64
+#endif
+
+#ifndef GGML_CUDA_GDN_CHUNKED
+#    define GGML_CUDA_GDN_CHUNKED 1
+#endif
+
+// RDNA3.5 (gfx1151): 64 KiB LDS; chunk output kernel with CS=64, S_v=128 exceeds the limit.
+#if defined(RDNA3_5)
+#    undef GGML_CUDA_GDN_CHUNKED
+#    define GGML_CUDA_GDN_CHUNKED 0
+#endif
+
+static int ggml_cuda_gdn_chunk_threshold_runtime() {
+    static int thresh = -1;
+    if (thresh < 0) {
+        const char * env = getenv("GGML_CUDA_GDN_CHUNK_THRESHOLD");
+        thresh           = env ? atoi(env) : GGML_CUDA_GDN_CHUNK_THRESHOLD;
+        if (thresh < 1) {
+            thresh = GGML_CUDA_GDN_CHUNK_THRESHOLD;
+        }
+    }
+    return thresh;
+}
+
+static bool ggml_cuda_gdn_chunked_enabled_runtime() {
+#if !GGML_CUDA_GDN_CHUNKED
+    return false;
+#else
+    static int enabled = -1;
+    if (enabled < 0) {
+        const char * env = getenv("GGML_CUDA_GDN_CHUNKED");
+        if (env != nullptr &&
+            (env[0] == '0' || env[0] == 'f' || env[0] == 'F' || env[0] == 'n' || env[0] == 'N')) {
+            enabled = 0;
+        } else {
+            enabled = 1;
+        }
+    }
+    return enabled != 0;
+#endif
+}
+
+bool ggml_cuda_gdn_use_chunked_prefill(int64_t n_tokens, int64_t S_v, bool kda, int K) {
+#if !GGML_CUDA_GDN_CHUNKED
+    GGML_UNUSED(n_tokens);
+    GGML_UNUSED(S_v);
+    GGML_UNUSED(kda);
+    GGML_UNUSED(K);
+    return false;
+#else
+    if (!ggml_cuda_gdn_chunked_enabled_runtime()) {
+        return false;
+    }
+    if (kda || K > 1) {
+        return false;
+    }
+    if (n_tokens < ggml_cuda_gdn_chunk_threshold_runtime()) {
+        return false;
+    }
+    return S_v == 128;
+#endif
+}
+
+#if GGML_CUDA_GDN_CHUNKED
+
+template <size_t CS>
+static __global__ void gdn_chunk_cumsum_kernel(const float * g,
+                                               float *       g_cs,
+                                               int64_t       sg1,
+                                               int64_t       sg2,
+                                               int64_t       sg3,
+                                               int64_t       ng1,
+                                               int64_t       ng3) {
+    const int h_idx     = blockIdx.x;
+    const int chunk_idx = blockIdx.y;
+    const int seq_idx   = blockIdx.z;
+
+    const float * g_ch  = g + h_idx * sg1 + chunk_idx * CS * sg2 + seq_idx * sg3;
+    float *       g_out = g_cs + h_idx * ng1 + chunk_idx * CS + seq_idx * ng3;
+
+    float acc = 0.0f;
+    for (int i = 0; i < (int) CS; ++i) {
+        acc += g_ch[i * sg2];
+        g_out[i] = acc;
+    }
+}
+
+template <size_t CS, size_t S_v>
+static __global__ void gdn_chunk_kkt_kernel(const float * k,
+                                             const float * q,
+                                             const float * g_cs,
+                                             const float * beta,
+                                             float *       Akk,
+                                             float *       Akq,
+                                             int64_t       sk1,
+                                             int64_t       sk2,
+                                             int64_t       sk3,
+                                             int64_t       sg1,
+                                             int64_t       sg3,
+                                             int64_t       sb1,
+                                             int64_t       sb2,
+                                             int64_t       sb3,
+                                             float         scale) {
+    const int h_idx     = blockIdx.x;
+    const int chunk_idx = blockIdx.y;
+    const int seq_idx   = blockIdx.z;
+
+    const float * k_base = k + h_idx * sk1 + chunk_idx * CS * sk2 + seq_idx * sk3;
+    const float * q_base = q + h_idx * sk1 + chunk_idx * CS * sk2 + seq_idx * sk3;
+    const float * g_base = g_cs + h_idx * sg1 + chunk_idx * CS + seq_idx * sg3;
+    const float * b_base = beta + h_idx * sb1 + chunk_idx * CS * sb2 + seq_idx * sb3;
+
+    const int64_t batch_off = ((int64_t) seq_idx * gridDim.x * gridDim.y + h_idx * gridDim.y + chunk_idx) * CS * CS;
+    float *       akk       = Akk + batch_off;
+    float *       akq       = Akq + batch_off;
+
+    for (int idx = threadIdx.x; idx < (int) (CS * CS); idx += blockDim.x) {
+        const int i = idx % CS;
+        const int j = idx / CS;
+
+        if (i <= j) {
+            float dot_k = 0.0f;
+            float dot_q = 0.0f;
+            for (int d = 0; d < (int) S_v; ++d) {
+                const float kd   = k_base[i * sk2 + d];
+                const float kd_j = k_base[j * sk2 + d];
+                dot_k += kd * kd_j;
+                dot_q += kd * q_base[j * sk2 + d];
+            }
+            const float decay = expf(g_base[j] - g_base[i]);
+            const float bj    = b_base[j * sb2];
+            akk[i + j * CS]   = dot_k * bj * decay;
+            akq[i + j * CS]   = dot_q * decay * scale;
+        } else {
+            akk[i + j * CS] = 0.0f;
+            akq[i + j * CS] = 0.0f;
+        }
+    }
+}
+
+template <size_t CS>
+static __global__ void gdn_chunk_prepare_solve_kernel(const float * A, float * lhs, float * rhs) {
+    const int64_t offset = (int64_t) blockIdx.x * CS * CS;
+    const float * A_b      = A + offset;
+    float *       lhs_b    = lhs + offset;
+    float *       rhs_b    = rhs + offset;
+
+    for (int idx = threadIdx.x; idx < (int) (CS * CS); idx += blockDim.x) {
+        const int i   = idx % CS;
+        const int j   = idx / CS;
+        const float v = A_b[idx];
+
+        if (i < j) {
+            lhs_b[idx] = v;
+            rhs_b[idx] = -v;
+        } else if (i == j) {
+            lhs_b[idx] = 1.0f;
+            rhs_b[idx] = 0.0f;
+        } else {
+            lhs_b[idx] = 0.0f;
+            rhs_b[idx] = 0.0f;
+        }
+    }
+}
+
+template <size_t CS>
+static __global__ void gdn_chunk_add_identity_kernel(float * X) {
+    const int64_t offset = (int64_t) blockIdx.x * CS * CS;
+    float *       X_b    = X + offset;
+    const int     tid    = threadIdx.x;
+    if (tid < (int) CS) {
+        X_b[tid + tid * CS] += 1.0f;
+    }
+}
+
+template <size_t CS, size_t S_v>
+static __global__ void gdn_chunk_wu_kernel(const float * k,
+                                           const float * v,
+                                           const float * A,
+                                           const float * beta,
+                                           const float * gate_cs,
+                                           float *       k_cd,
+                                           float *       v_new,
+                                           int64_t       sk1,
+                                           int64_t       sk2,
+                                           int64_t       sk3,
+                                           int64_t       sv1,
+                                           int64_t       sv2,
+                                           int64_t       sv3,
+                                           int64_t       sa1,
+                                           int64_t       sa2,
+                                           int64_t       sa3,
+                                           int64_t       sb1,
+                                           int64_t       sb2,
+                                           int64_t       sb3,
+                                           int64_t       sg1,
+                                           int64_t       sg3,
+                                           int64_t       sd1,
+                                           int64_t       sd2,
+                                           int64_t       sd3) {
+    const int h_idx     = blockIdx.x;
+    const int chunk_idx = blockIdx.y;
+    const int seq_idx   = blockIdx.z;
+
+    const float * k_ch = k + h_idx * sk1 + chunk_idx * CS * sk2 + seq_idx * sk3;
+    const float * v_ch = v + h_idx * sv1 + chunk_idx * CS * sv2 + seq_idx * sv3;
+    const float * g_ch = gate_cs + h_idx * sg1 + chunk_idx * CS + seq_idx * sg3;
+    const float * b_ch = beta + h_idx * sb1 + chunk_idx * CS * sb2 + seq_idx * sb3;
+    const float * A_ch = A + ((int64_t) seq_idx * sa3 + h_idx * sa2 + chunk_idx * sa1) * CS * CS;
+
+    float * kcd_out = k_cd + h_idx * sd1 + chunk_idx * sd2 + seq_idx * sd3;
+    float * v_out   = v_new + h_idx * sd1 + chunk_idx * sd2 + seq_idx * sd3;
+
+    __shared__ float A_s[CS * CS];
+    for (int idx = threadIdx.x; idx < (int) (CS * CS); idx += blockDim.x) {
+        A_s[idx] = A_ch[idx];
+    }
+    __syncthreads();
+
+    for (int idx = threadIdx.x; idx < (int) (S_v * CS); idx += blockDim.x) {
+        const int d = idx / CS;
+        const int t = idx % CS;
+
+        float sum_k = 0.0f;
+        float sum_v = 0.0f;
+        const float kb = b_ch[t * sb2];
+        const float kg = kb * expf(g_ch[t]);
+        for (int j = 0; j < (int) CS; ++j) {
+            sum_k += A_s[t + j * CS] * k_ch[j * sk2 + d] * kg;
+            sum_v += A_s[t + j * CS] * v_ch[j * sv2 + d] * kb;
+        }
+        kcd_out[d + t * S_v] = sum_k;
+        v_out[d + t * S_v]   = sum_v;
+    }
+}
+
+// State layout matches AR kernel: S[i][col] at col * S_v + i (transposed).
+template <size_t CS, size_t S_v>
+static __global__ void gdn_chunk_state_kernel(const float * k_raw,
+                                              float *       v_new,
+                                              const float * k_cd,
+                                              const float * g_cs,
+                                              const float * state_in,
+                                              float *       states_out,
+                                              float *       state_final,
+                                              int64_t       sk1,
+                                              int64_t       sk2,
+                                              int64_t       sk3,
+                                              int64_t       ng1,
+                                              int64_t       ng3,
+                                              int64_t       sd1,
+                                              int64_t       sd2,
+                                              int64_t       sd3,
+                                              int64_t       n_chunks,
+                                              int64_t       H) {
+    const int h_idx   = blockIdx.x;
+    const int seq_idx = blockIdx.y;
+    const int64_t hs  = (int64_t) seq_idx * H + h_idx;
+
+    __shared__ float smem_state[S_v * S_v];
+
+    const float * s_in = state_in + hs * S_v * S_v;
+    for (int idx = threadIdx.x; idx < (int) (S_v * S_v); idx += blockDim.x) {
+        smem_state[idx] = s_in[idx];
+    }
+    __syncthreads();
+
+    for (int c = 0; c < (int) n_chunks; ++c) {
+        float * s_out = states_out + (hs * n_chunks + c) * S_v * S_v;
+        for (int idx = threadIdx.x; idx < (int) (S_v * S_v); idx += blockDim.x) {
+            s_out[idx] = smem_state[idx];
+        }
+        __syncthreads();
+
+        const float * kcd_ptr = k_cd + h_idx * sd1 + c * sd2 + seq_idx * sd3;
+        float *       v_ptr   = v_new + h_idx * sd1 + c * sd2 + seq_idx * sd3;
+
+        // v_new[t, col] -= sum_k k_cd[k, t] * S[k, col]
+        for (int idx = threadIdx.x; idx < (int) (S_v * CS); idx += blockDim.x) {
+            const int col = idx / CS;
+            const int t   = idx % CS;
+
+            float vp = 0.0f;
+            for (int k = 0; k < (int) S_v; ++k) {
+                vp += kcd_ptr[k + t * S_v] * smem_state[col * S_v + k];
+            }
+            v_ptr[col + t * S_v] -= vp;
+        }
+        __syncthreads();
+
+        const float * k_ch = k_raw + h_idx * sk1 + seq_idx * sk3 + c * (int64_t) CS * sk2;
+        const float * g_ch = g_cs + h_idx * ng1 + c * CS + seq_idx * ng3;
+        const float   g_last = g_ch[CS - 1];
+        const float   gate   = expf(g_last);
+
+        // S[i][col] = gate * S[i][col] + sum_t k[i,t]*exp(g_last-g[t]) * v_new[t,col]
+        for (int idx = threadIdx.x; idx < (int) (S_v * S_v); idx += blockDim.x) {
+            const int col = idx / S_v;
+            const int i   = idx % S_v;
+
+            float kgv = 0.0f;
+            for (int t = 0; t < (int) CS; ++t) {
+                kgv += k_ch[i + t * sk2] * expf(g_last - g_ch[t]) * v_ptr[col + t * S_v];
+            }
+            smem_state[col * S_v + i] = gate * smem_state[col * S_v + i] + kgv;
+        }
+        __syncthreads();
+    }
+
+    float * s_final = state_final + hs * S_v * S_v;
+    for (int idx = threadIdx.x; idx < (int) (S_v * S_v); idx += blockDim.x) {
+        s_final[idx] = smem_state[idx];
+    }
+}
+
+template <size_t CS, size_t S_v>
+static __global__ void gdn_chunk_output_kernel(const float * q,
+                                               const float * v_delta,
+                                               const float * Akq,
+                                               const float * states,
+                                               const float * g_cs,
+                                               float *       output,
+                                               int64_t       sq1,
+                                               int64_t       sq2,
+                                               int64_t       sq3,
+                                               int64_t       ng1,
+                                               int64_t       ng3,
+                                               int64_t       sd1,
+                                               int64_t       sd2,
+                                               int64_t       sd3,
+                                               int64_t       n_chunks,
+                                               int64_t       H,
+                                               int64_t       n_tokens,
+                                               float         scale) {
+    const int h_idx     = blockIdx.x;
+    const int seq_idx   = blockIdx.y;
+    const int chunk_idx = blockIdx.z;
+    const int64_t hs    = (int64_t) seq_idx * H + h_idx;
+
+    const float * chunk_state = states + (hs * n_chunks + chunk_idx) * S_v * S_v;
+    const float * chunk_vd    = v_delta + h_idx * sd1 + chunk_idx * sd2 + seq_idx * sd3;
+    const float * chunk_akq   = Akq + ((int64_t) seq_idx * H * n_chunks + h_idx * n_chunks + chunk_idx) * CS * CS;
+    const float * chunk_g     = g_cs + h_idx * ng1 + chunk_idx * CS + seq_idx * ng3;
+    const float * q_base      = q + h_idx * sq1 + seq_idx * sq3 + chunk_idx * (int64_t) CS * sq2;
+    float *       out_base    = output + h_idx * S_v + seq_idx * n_tokens * S_v * H + chunk_idx * (int64_t) CS * S_v * H;
+
+    __shared__ float s_akq[CS * CS];
+    __shared__ float s_gexp[CS];
+
+    for (int idx = threadIdx.x; idx < (int) (CS * CS); idx += blockDim.x) {
+        s_akq[idx] = chunk_akq[idx];
+    }
+    if (threadIdx.x < (int) CS) {
+        s_gexp[threadIdx.x] = expf(chunk_g[threadIdx.x]);
+    }
+    __syncthreads();
+
+    for (int idx = threadIdx.x; idx < (int) (S_v * CS); idx += blockDim.x) {
+        const int d = idx / CS;
+        const int t = idx % CS;
+
+        float attn = 0.0f;
+        for (int i = 0; i < (int) S_v; ++i) {
+            attn += chunk_state[d * S_v + i] * q_base[i + t * sq2] * s_gexp[t];
+        }
+        attn *= scale;
+
+        float v_attn = 0.0f;
+        for (int j = 0; j <= t; ++j) {
+            v_attn += chunk_vd[d + j * S_v] * s_akq[j + t * CS];
+        }
+
+        out_base[d + t * S_v * H] = attn + v_attn;
+    }
+}
+
+void ggml_cuda_gdn_chunked_prefill(
+        ggml_backend_cuda_context & ctx,
+        const float *               q_d,
+        const float *               k_d,
+        const float *               v_d,
+        const float *               g_d,
+        const float *               b_d,
+        const float *               s_d,
+        float *                     dst_d,
+        float *                     state_d,
+        int64_t                     S_v,
+        int64_t                     H,
+        int64_t                     n_tokens,
+        int64_t                     n_seqs,
+        int64_t                     sq1,
+        int64_t                     sq2,
+        int64_t                     sq3,
+        int64_t                     sv1,
+        int64_t                     sv2,
+        int64_t                     sv3,
+        int64_t                     sb1,
+        int64_t                     sb2,
+        int64_t                     sb3,
+        int64_t                     sg1,
+        int64_t                     sg2,
+        int64_t                     sg3,
+        int64_t                     neqk1,
+        int64_t                     rq3,
+        float                       scale,
+        cudaStream_t                stream) {
+    static constexpr int CS = GGML_CUDA_GDN_CHUNK_SIZE;
+
+    const int64_t n_full  = (n_tokens / CS) * CS;
+    const int64_t n_tail  = n_tokens - n_full;
+    const int     n_chunks = (int) (n_full / CS);
+
+    if (n_chunks == 0) {
+        ggml_cuda_gdn_launch_ar(
+            q_d, k_d, v_d, g_d, b_d, s_d, dst_d, state_d,
+            S_v, H, n_tokens, n_seqs, sq1, sq2, sq3, sv1, sv2, sv3,
+            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, 0.0f, n_tokens, 0, stream);
+        return;
+    }
+
+    const int64_t ng1 = CS * n_chunks;
+    const int64_t ng3 = CS * n_chunks * H;
+
+    ggml_cuda_pool_alloc<float> gate_csum(ctx.pool(), CS * n_chunks * H * n_seqs);
+    ggml_cuda_pool_alloc<float> Akk(ctx.pool(), CS * CS * n_chunks * H * n_seqs);
+    ggml_cuda_pool_alloc<float> Akq(ctx.pool(), CS * CS * n_chunks * H * n_seqs);
+
+    {
+        dim3 grid(H, n_chunks, n_seqs);
+        gdn_chunk_cumsum_kernel<CS><<<grid, 1, 0, stream>>>(
+            g_d, gate_csum.get(), sg1, sg2, sg3, ng1, ng3);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    {
+        dim3 grid(H, n_chunks, n_seqs);
+        dim3 block(256);
+        gdn_chunk_kkt_kernel<CS, 128><<<grid, block, 0, stream>>>(
+            k_d, q_d, gate_csum.get(), b_d, Akk.get(), Akq.get(),
+            sq1, sq2, sq3, ng1, ng3, sb1, sb2, sb3, scale);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    {
+        const int64_t n_batches = (int64_t) n_chunks * H * n_seqs;
+        ggml_cuda_pool_alloc<float> lhs(ctx.pool(), CS * CS * n_batches);
+        ggml_cuda_pool_alloc<float> rhs(ctx.pool(), CS * CS * n_batches);
+
+        gdn_chunk_prepare_solve_kernel<CS><<<n_batches, 256, 0, stream>>>(
+            Akk.get(), lhs.get(), rhs.get());
+        CUDA_CHECK(cudaGetLastError());
+
+        const size_t bs = CS * CS;
+        ggml_cuda_solve_tri_f32(ctx, lhs.get(), rhs.get(), Akk.get(), CS, CS,
+            n_batches, 1, bs, bs * n_batches, bs, bs * n_batches, bs, bs * n_batches, stream);
+
+        gdn_chunk_add_identity_kernel<CS><<<n_batches, CS, 0, stream>>>(Akk.get());
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    const int64_t sd1 = S_v * CS * n_chunks;
+    const int64_t sd2 = S_v * CS;
+    const int64_t sd3 = S_v * CS * n_chunks * H;
+
+    ggml_cuda_pool_alloc<float> k_cd(ctx.pool(), S_v * CS * n_chunks * H * n_seqs);
+    ggml_cuda_pool_alloc<float> v_new(ctx.pool(), S_v * CS * n_chunks * H * n_seqs);
+
+    {
+        const int64_t sa1 = CS * CS;
+        const int64_t sa2 = CS * CS * n_chunks;
+        const int64_t sa3 = CS * CS * n_chunks * H;
+
+        dim3 grid(H, n_chunks, n_seqs);
+        gdn_chunk_wu_kernel<CS, 128><<<grid, 256, 0, stream>>>(
+            k_d, v_d, Akk.get(), b_d, gate_csum.get(), k_cd.get(), v_new.get(),
+            sq1, sq2, sq3, sv1, sv2, sv3, sa1, sa2, sa3, sb1, sb2, sb3, ng1, ng3, sd1, sd2, sd3);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    ggml_cuda_pool_alloc<float> states(ctx.pool(), S_v * S_v * n_chunks * H * n_seqs);
+    ggml_cuda_pool_alloc<float> state_out(ctx.pool(), S_v * S_v * H * n_seqs);
+
+    {
+        dim3 grid(H, n_seqs);
+        gdn_chunk_state_kernel<CS, 128><<<grid, 256, 0, stream>>>(
+            k_d, v_new.get(), k_cd.get(), gate_csum.get(), s_d,
+            states.get(), state_out.get(),
+            sq1, sq2, sq3, ng1, ng3, sd1, sd2, sd3, n_chunks, H);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    {
+        dim3 grid(H, n_seqs, n_chunks);
+        gdn_chunk_output_kernel<CS, 128><<<grid, 256, 0, stream>>>(
+            q_d, v_new.get(), Akq.get(), states.get(), gate_csum.get(), dst_d,
+            sq1, sq2, sq3, ng1, ng3, sd1, sd2, sd3, n_chunks, H, n_tokens, scale);
+        CUDA_CHECK(cudaGetLastError());
+    }
+
+    if (n_tail == 0) {
+        CUDA_CHECK(cudaMemcpyAsync(state_d, state_out.get(), S_v * S_v * H * n_seqs * sizeof(float),
+                                   cudaMemcpyDeviceToDevice, stream));
+    } else {
+        const float * q_tail = q_d + n_full * sq2;
+        const float * k_tail = k_d + n_full * sq2;
+        const float * v_tail = v_d + n_full * sv2;
+        const float * g_tail = g_d + n_full * sg2;
+        const float * b_tail = b_d + n_full * sb2;
+
+        ggml_cuda_gdn_launch_ar(
+            q_tail, k_tail, v_tail, g_tail, b_tail, state_out.get(), dst_d, state_d,
+            S_v, H, n_tail, n_seqs, sq1, sq2, sq3, sv1, sv2, sv3,
+            sb1, sb2, sb3, neqk1, rq3, scale, 0, 1, 0.0f, n_tokens, n_full, stream);
+    }
+}
+
+#else
+
+void ggml_cuda_gdn_chunked_prefill(
+        ggml_backend_cuda_context & ctx,
+        const float *               q_d,
+        const float *               k_d,
+        const float *               v_d,
+        const float *               g_d,
+        const float *               b_d,
+        const float *               s_d,
+        float *                     dst_d,
+        float *                     state_d,
+        int64_t                     S_v,
+        int64_t                     H,
+        int64_t                     n_tokens,
+        int64_t                     n_seqs,
+        int64_t                     sq1,
+        int64_t                     sq2,
+        int64_t                     sq3,
+        int64_t                     sv1,
+        int64_t                     sv2,
+        int64_t                     sv3,
+        int64_t                     sb1,
+        int64_t                     sb2,
+        int64_t                     sb3,
+        int64_t                     sg1,
+        int64_t                     sg2,
+        int64_t                     sg3,
+        int64_t                     neqk1,
+        int64_t                     rq3,
+        float                       scale,
+        cudaStream_t                stream) {
+    GGML_UNUSED(ctx);
+    GGML_UNUSED(q_d);
+    GGML_UNUSED(k_d);
+    GGML_UNUSED(v_d);
+    GGML_UNUSED(g_d);
+    GGML_UNUSED(b_d);
+    GGML_UNUSED(s_d);
+    GGML_UNUSED(dst_d);
+    GGML_UNUSED(state_d);
+    GGML_UNUSED(S_v);
+    GGML_UNUSED(H);
+    GGML_UNUSED(n_tokens);
+    GGML_UNUSED(n_seqs);
+    GGML_UNUSED(sq1);
+    GGML_UNUSED(sq2);
+    GGML_UNUSED(sq3);
+    GGML_UNUSED(sv1);
+    GGML_UNUSED(sv2);
+    GGML_UNUSED(sv3);
+    GGML_UNUSED(sb1);
+    GGML_UNUSED(sb2);
+    GGML_UNUSED(sb3);
+    GGML_UNUSED(sg1);
+    GGML_UNUSED(sg2);
+    GGML_UNUSED(sg3);
+    GGML_UNUSED(neqk1);
+    GGML_UNUSED(rq3);
+    GGML_UNUSED(scale);
+    GGML_UNUSED(stream);
+    GGML_ABORT("ggml_cuda_gdn_chunked_prefill called but GGML_CUDA_GDN_CHUNKED=0");
+}
+
+#endif // GGML_CUDA_GDN_CHUNKED
