+bool llama_context::ensure_embd_nextn_dev(int64_t n_embd, int64_t n_rows) {
+    if (!cparams.embeddings_nextn_gpu_resident || n_embd <= 0 || n_rows <= 0) {
+        return false;
+    }
+
+    const size_t nbytes = (size_t) n_embd * (size_t) n_rows * sizeof(float);
+
+    if (buf_embd_nextn_dev && ggml_backend_buffer_get_size(buf_embd_nextn_dev.get()) >= nbytes && t_embd_nextn_dev) {
+        return true;
+    }
+
+    synchronize();
+
+    buf_embd_nextn_dev = nullptr;
+    t_embd_nextn_dev   = nullptr;
+    ctx_embd_nextn_dev = nullptr;
+
+    ggml_backend_dev_t dev = model.dev_output();
+    if (!dev) {
+        return false;
+    }
+
+    ggml_backend_buffer_type_t buft = ggml_backend_dev_buffer_type(dev);
+    if (!buft) {
+        return false;
+    }
+
+    buf_embd_nextn_dev.reset(ggml_backend_buft_alloc_buffer(buft, nbytes));
+    if (!buf_embd_nextn_dev) {
+        return false;
+    }
+
+    ggml_init_params params = {
+        /*.mem_size   =*/ ggml_tensor_overhead(),
+        /*.mem_buffer =*/ nullptr,
+        /*.no_alloc   =*/ true,
+    };
+
+    ctx_embd_nextn_dev.reset(ggml_init(params));
+    if (!ctx_embd_nextn_dev) {
+        buf_embd_nextn_dev = nullptr;
+        return false;
+    }
+
+    t_embd_nextn_dev = ggml_new_tensor_2d(ctx_embd_nextn_dev.get(), GGML_TYPE_F32, n_embd, n_rows);
+    void * base = ggml_backend_buffer_get_base(buf_embd_nextn_dev.get());
+    if (ggml_backend_tensor_alloc(buf_embd_nextn_dev.get(), t_embd_nextn_dev, base) != GGML_STATUS_SUCCESS) {
+        buf_embd_nextn_dev = nullptr;
+        t_embd_nextn_dev   = nullptr;
+        ctx_embd_nextn_dev = nullptr;
+        return false;
+    }
+
+    return true;
+}
+
+void llama_context::copy_embd_rows_dev(
+        ggml_tensor * dst,
+        int32_t       dst_row,
+        ggml_tensor * src,
+        int32_t       src_row,
+        int32_t       n_rows,
+        int32_t       n_embd) {
+    if (!ctx_embd_nextn_dev || n_rows <= 0 || !dst || !src) {
+        return;
+    }
+
+    ggml_context * ctx = ctx_embd_nextn_dev.get();
+
+    for (int32_t i = 0; i < n_rows; ++i) {
+        ggml_tensor * src_view = ggml_view_2d(
+                ctx, src,
+                n_embd, 1,
+                src->nb[1],
+                (int64_t) (src_row + i) * src->nb[1]);
+
+        ggml_tensor * dst_view = ggml_view_2d(
+                ctx, dst,
+                n_embd, 1,
+                dst->nb[1],
+                (int64_t) (dst_row + i) * dst->nb[1]);
+
+        ggml_backend_tensor_copy(src_view, dst_view);
+    }
+}
+
+void llama_context::handle_mtp_for_ubatch(
+        const llama_ubatch & ubatch,
+        const llm_graph_result * res,
+        int64_t n_tokens_prev,
+        int64_t n_outputs_prev) {
+    if (!cparams.embeddings_nextn || !cparams.embeddings_nextn_gpu_resident) {
+        return;
+    }
+
+    ggml_tensor * t_h_nextn = res->get_h_nextn();
+    if (!t_h_nextn || !t_embd_nextn_dev) {
+        return;
+    }
+
+    const int32_t n_embd = (int32_t) model.hparams.n_embd_out();
+    const bool masked    = cparams.embeddings_nextn_masked;
+    const int64_t n_rows = masked ? n_outputs : (int64_t) ubatch.n_tokens;
+    const int64_t offset = masked ? n_outputs_prev  : n_tokens_prev;
+
+    if (n_rows <= 0) {
+        return;
+    }
+
+    GGML_ASSERT(offset + n_rows <= t_embd_nextn_dev->ne[1]);
+
+    ggml_context * ctx = ctx_embd_nextn_dev.get();
+
+    ggml_tensor * src_view = ggml_view_2d(ctx, t_h_nextn, n_embd, n_rows, t_h_nextn->nb[1], 0);
+    ggml_tensor * dst_view = ggml_view_2d(
+            ctx, t_embd_nextn_dev, n_embd, n_rows, t_embd_nextn_dev->nb[1],
+            offset * t_embd_nextn_dev->nb[1]);
+
+    ggml_backend_tensor_copy(src_view, dst_view);
+}
+
+void llama_context::apply_mtp_h_pending(const llm_graph_result * res) {
+    if (mtp_h_pending.empty()) {
+        return;
+    }
+
+    ggml_tensor * t_inp_h = res->get_inp_h();
+    if (!t_inp_h) {
+        mtp_h_pending.clear();
+        return;
+    }
+
+    const int32_t n_embd = (int32_t) model.hparams.n_embd_out();
+
+    for (const auto & spec : mtp_h_pending) {
+        if (!spec.src_ctx || !spec.src_ctx->t_embd_nextn_dev) {
+            continue;
+        }
+
+        copy_embd_rows_dev(
+                t_inp_h, spec.dst_row,
+                spec.src_ctx->t_embd_nextn_dev, spec.src_row,
+                spec.n_rows, n_embd);
+    }
+
+    mtp_h_pending.clear();
+}
+
+void llama_context::mtp_clear_h_pending() {
+    mtp_h_pending.clear();
+}
+
+void llama_context::mtp_queue_h_rows(llama_context * src, int32_t dst_row, int32_t src_row, int32_t n_rows) {
+    if (n_rows <= 0) {
+        return;
+    }
+
+    mtp_h_pending.push_back({ src, dst_row, src_row, n_rows });
+}
+
+bool llama_context::mtp_get_h_row(int32_t row, float * dst, int32_t n_embd) {
+    if (!dst || !t_embd_nextn_dev || row < 0 || row >= (int32_t) t_embd_nextn_dev->ne[1]) {
+        return false;
+    }
+
+    ggml_context * ctx = ctx_embd_nextn_dev.get();
+    ggml_tensor * src_view = ggml_view_2d(
+            ctx, t_embd_nextn_dev, n_embd, 1, t_embd_nextn_dev->nb[1], (int64_t) row * t_embd_nextn_dev->nb[1]);
+
+    ggml_backend_tensor_get(src_view, dst, 0, (size_t) n_embd * sizeof(float));
+    return true;
+}
